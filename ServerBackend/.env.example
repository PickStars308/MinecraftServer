# 后端服务配置
PORT=3003

# CORS 配置
# 开发环境：http://localhost:5173,http://127.0.0.1:5173
# 生产环境：https://yourdomain.com
# 多个域名用逗号分隔
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Minecraft 服务器状态查询配置
MC_SERVER_IP=localhost
MC_SERVER_PORT=25565
QUERY_INTERVAL=10000

# Session 配置
ADMIN_SESSION_SECRET=

# 加密配置
# Caesar 密码偏移量
CAESAR_OFFSET=
# Caesar 密码验证 Token
CAESAR_VALID_TOKEN=

# AES 加密密钥（16 位）
AES_SECRET_KEY=
# AES 加密向量（16 位）
AES_IV=
